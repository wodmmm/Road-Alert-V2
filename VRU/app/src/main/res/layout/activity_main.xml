<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_slate"
    android:padding="24dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ROAD ALERT"
        android:textColor="@color/safety_blue"
        android:textSize="24sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp" />

    <LinearLayout
        android:id="@+id/statusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/titleText">

        <TextView
            android:id="@+id/gpsStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="GPS: Waiting"
            android:textColor="@color/white"
            android:alpha="0.6"
            android:textAlignment="center" />

        <TextView
            android:id="@+id/connStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MQTT: Off"
            android:textColor="@color/white"
            android:alpha="0.6"
            android:textAlignment="center" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/selectionGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/statusRow">

        <Button
            android:id="@+id/btnHorse"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="HORSE"
            android:backgroundTint="@color/panel_bg" />

        <Button
            android:id="@+id/btnWalker"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="WALKER"
            android:backgroundTint="@color/panel_bg" />

        <Button
            android:id="@+id/btnCyclist"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="CYCLIST"
            android:backgroundTint="@color/panel_bg" />

        <Button
            android:id="@+id/btnRunner"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            android:text="RUNNER"
            android:backgroundTint="@color/panel_bg" />

    </GridLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/startStopBtn"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="START"
        android:textSize="24sp"
        android:textStyle="bold"
        app:cornerRadius="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/selectionGrid"
        android:layout_marginBottom="32dp"
        android:backgroundTint="@color/safety_blue" />

</androidx.constraintlayout.widget.ConstraintLayout>